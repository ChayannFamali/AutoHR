# AutoHR — пример .env файла
# Скопируйте в .env и заполните реальные значения

# === Режим ===
DEBUG=True
SECRET_KEY=change-me-in-production-please-use-strong-random-key
ALLOWED_HOSTS=localhost,127.0.0.1

# === База данных ===
# SQLite (default, dev)
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (prod, требует docker-compose up db)
# DATABASE_URL=postgresql://autohr:autohr@db:5432/autohr

# === AI (опционально) ===
AI_ENABLED=False
# AI_ENABLED=True  # Включить ИИ-рекомендации (требует ~1GB RAM)

# === CORS (Этап 5.2) ===
# Включить для внешнего фронта:
# CORS_ENABLED=True
# CORS_ALLOWED_ORIGINS=https://my-frontend.example.com,https://admin.example.com
# CORS_ALLOW_CREDENTIALS=True

# === Бэкапы (Этап 5.7) ===
BACKUP_DIR=/path/to/backups
# Пример для cron: 0 3 * * * cd /app && /app/.venv/bin/python manage.py backup_db --keep 14

# === Email (notifications) ===
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=AutoHR <noreply@autohr.com>